# MusicGrabber Environment Variables
# Copy to .env and fill in your values. DO NOT commit .env to git!

# ── Database ─────────────────────────────
ConnectionStrings__Default=Data Source=/data/musicgrabber.db

# ── Google OAuth (from Passbolt) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── YouTube API (from Passbolt) ──────────
YOUTUBE_API_KEY=

# ── Authentik OIDC (homelab SSO) ─────────
AUTHENTIK_AUTHORITY=https://auth.home.freaxnx01.ch/application/o/musicgrabber/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# ── SMTP (Mailcow on VPS-DE) ────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_PASSWORD=
SMTP_FROM=

# ── Optional ─────────────────────────────
Serilog__MinimumLevel=Information
OTEL_EXPORTER_OTLP_ENDPOINT=

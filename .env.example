# Music Grabber Environment Variables
# Copy this file to .env and fill in the values
# DO NOT commit .env to git!

# API Key for service-to-service authentication
API_KEY=change-this-in-production

# Development user configuration (for DevAuthHandler)
DEV_EMAIL=admin@example.com
DEV_NAME=Admin User
DEV_ROLE=Admin

# YouTube Data API v3 Configuration
# Get API key from Google Cloud Console: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key-here

# Google OAuth 2.0 Configuration
# Get from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Client ID looks like: 123456789-abc123.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id-here
# Client Secret looks like: GOCSPX-xyz789...
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# SMTP Configuration for email notifications
# Get password from Passbolt (entry ID: mgrabber-smtp)
SMTP_PASSWORD=your-smtp-password-here

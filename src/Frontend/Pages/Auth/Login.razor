@page "/login"
@layout EmptyLayout

<MudThemeProvider />

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
    <MudPaper Elevation="4" Class="pa-8 d-flex flex-column align-center" Style="max-width: 400px; width: 100%;">
        <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.h4" Class="mt-4">MusicGrabber</MudText>
        <MudButton Href="/api/auth/google-login"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Login"
                   Class="mt-6">
            Login with Google
        </MudButton>
        <MudButton Href="/api/auth/authentik-login"
                   Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   FullWidth
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Security"
                   Class="mt-2">
            Login with Authentik
        </MudButton>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4" Align="Align.Center">
            Access requires an active whitelist entry.
        </MudText>
    </MudPaper>
</MudContainer>

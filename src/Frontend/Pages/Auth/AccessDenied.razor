@page "/access-denied"
@layout EmptyLayout

<MudThemeProvider />

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
    <MudPaper Elevation="4" Class="pa-8 d-flex flex-column align-center" Style="max-width: 400px; width: 100%;">
        <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Large" Color="Color.Error" />
        <MudText Typo="Typo.h5" Class="mt-4">Access Denied</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2" Align="Align.Center">
            Your account is not whitelisted or has been disabled. Contact an administrator.
        </MudText>
        <MudButton Href="/login"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Class="mt-4">
            Back to Login
        </MudButton>
    </MudPaper>
</MudContainer>

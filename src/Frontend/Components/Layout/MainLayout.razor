@inherits LayoutComponentBase
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div>
                @if (IsDevelopment)
                {
                    <span class="badge bg-warning text-dark me-2">⚠️ Development Mode</span>
                    <span class="text-muted small">Auth: @UserEmail (@UserRole)</span>
                }
            </div>
            <div>
                <a href="https://github.com/freaxnx01/mgrabber-nextgen" target="_blank">GitHub</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
<ReconnectModal />

@code {
    private bool IsDevelopment => HttpContextAccessor.HttpContext?.RequestServices
        .GetService<IWebHostEnvironment>()?.EnvironmentName == "Development";
    
    private string UserEmail => HttpContextAccessor.HttpContext?.User?.FindFirst(ClaimTypes.Email)?.Value ?? "unknown";
    private string UserRole => HttpContextAccessor.HttpContext?.User?.FindFirst(ClaimTypes.Role)?.Value ?? "unknown";
}

@page "/login"
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Google
@inject IConfiguration Configuration

<PageTitle>Login - Music Grabber</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header text-center">
                    <h3>🎵 Music Grabber</h3>
                    <p class="text-muted mb-0">Sign in to continue</p>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger">@ErrorMessage</div>
                    }

                    @if (IsGoogleConfigured)
                    {
                        <a href="/challenge/google" class="btn btn-danger btn-lg w-100 mb-3">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" 
                                 width="20" height="20" class="me-2" alt="Google" />
                            Sign in with Google
                        </a>
                        <hr />
                    }

                    @if (IsDevMode)
                    {
                        <div class="alert alert-info">
                            <strong>Development Mode</strong><br />
                            Automatically signed in as: <strong>@DevEmail</strong>
                        </div>
                        <a href="/" class="btn btn-primary w-100">Continue to App</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? ErrorMessage { get; set; }

    private bool IsGoogleConfigured => 
        !string.IsNullOrEmpty(Configuration["Authentication:Google:ClientId"]);

    private bool IsDevMode => 
        string.IsNullOrEmpty(Configuration["Authentication:Google:ClientId"]);

    private string DevEmail => 
        Configuration["DevAuth:Email"] ?? "admin@test.local";
}

@page "/musicbrainz"
@using Frontend.Services
@inject DownloadApiService DownloadApi
@inject NavigationManager Navigation
@inject ILogger<MusicBrainzSearch> Logger
@rendermode InteractiveServer

<PageTitle>MusicBrainz Search - Music Grabber</PageTitle>

<div class="container">
    <h1>🎵 MusicBrainz Search</h1>
    <p class="text-muted">Search for artists, tracks, and albums, then find them on YouTube</p>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert @MessageClass" role="alert">
            @Message
        </div>
    }

    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Search MusicBrainz</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">🔍</span>
                        <input type="text" class="form-control" 
                               @bind="SearchQuery" 
                               @bind:event="oninput"
                               @onkeypress="HandleKeyPress"
                               placeholder="Search for artist, track, or album..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="searchType" id="artist" 
                               value="artist" checked="@(SearchType == "artist")" @onchange="() => SearchType = "artist"" />
                        <label class="btn btn-outline-primary" for="artist">Artist</label>

                        <input type="radio" class="btn-check" name="searchType" id="track" 
                               value="track" checked="@(SearchType == "track")" @onchange="() => SearchType = "track"" />
                        <label class="btn btn-outline-primary" for="track">Track</label>

                        <input type="radio" class="btn-check" name="searchType" id="album" 
                               value="album" checked="@(SearchType == "album")" @onchange="() => SearchType = "album"" />
                        <label class="btn btn-outline-primary" for="album">Album</label>
                    </div>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col">
                    <button class="btn btn-primary" @onclick="SearchAsync" disabled="@IsSearching">
                        @if (IsSearching)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Search MusicBrainz
                    </button>
                    <button class="btn btn-outline-secondary ms-2" @onclick="ClearSearch">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Results -->
    @if (SearchResults != null)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Results for "@SearchResults.Query"</h5>
                <span class="badge bg-secondary">@SearchResults.TotalCount found</span>
            </div>
            <div class="card-body">
                @if (SearchResults.Type == "artist" && SearchResults.Artists.Any())
                {
                    <h6>Artists</h6>
                    <div class="list-group mb-3">
                        @foreach (var artist in SearchResults.Artists)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">@artist.Name</h6>
                                    <p class="mb-1 text-muted">
                                        @if (!string.IsNullOrEmpty(artist.Country))
                                        {
                                            <span class="badge bg-info me-1">@artist.Country</span>
                                        }
                                        @if (!string.IsNullOrEmpty(artist.Type))
                                        {
                                            <span class="badge bg-secondary me-1">@artist.Type</span>
                                        }
                                        @if (!string.IsNullOrEmpty(artist.Disambiguation))
                                        {
                                            <small>@artist.Disambiguation</small>
                                        }
                                    </p>
                                </div>
                                <div class="btn-group">
                                    <button class="btn btn-success btn-sm" 
                                            @onclick="() => SearchYouTube(artist.Name, isArtist: true)"
                                            title="Search YouTube for this artist">
                                        🎬 YouTube
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (SearchResults.Type == "track" && SearchResults.Tracks.Any())
                {
                    <h6>Tracks</h6>
                    <div class="list-group mb-3">
                        @foreach (var track in SearchResults.Tracks)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">@track.Title</h6>
                                    <p class="mb-1 text-muted">
                                        @if (!string.IsNullOrEmpty(track.Artist))
                                        {
                                            <span>by <strong>@track.Artist</strong></span>
                                        }
                                        @if (!string.IsNullOrEmpty(track.FormattedDuration))
                                        {
                                            <span class="ms-2 badge bg-secondary">@track.FormattedDuration</span>
                                        }
                                    </p>
                                </div>
                                <div class="btn-group">
                                    <button class="btn btn-success btn-sm" 
                                            @onclick="() => SearchYouTube($"{track.Artist} {track.Title}")"
                                            title="Search YouTube for this track">
                                        🎬 YouTube
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (SearchResults.Type == "release" && SearchResults.Releases.Any())
                {
                    <h6>Albums</h6>
                    <div class="list-group mb-3">
                        @foreach (var release in SearchResults.Releases)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">@release.Title</h6>
                                    <p class="mb-1 text-muted">
                                        @if (!string.IsNullOrEmpty(release.Artist))
                                        {
                                            <span>by <strong>@release.Artist</strong></span>
                                        }
                                        @if (!string.IsNullOrEmpty(release.Date))
                                        {
                                            <span class="ms-2 badge bg-info">@release.Date</span>
                                        }
                                        @if (release.TrackCount.HasValue)
                                        {
                                            <span class="ms-2 badge bg-secondary">@release.TrackCount tracks</span>
                                        }
                                    </p>
                                </div>
                                <div class="btn-group">
                                    <button class="btn btn-success btn-sm" 
                                            @onclick="() => SearchYouTube($"{release.Artist} {release.Title} album")"
                                            title="Search YouTube for this album">
                                        🎬 YouTube
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (!HasResults)
                {
                    <div class="text-center py-4">
                        <p class="text-muted">No results found. Try a different search term.</p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- YouTube Results Section -->
    @if (YouTubeResults != null)
    {
        <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">🎬 YouTube Results for "@YouTubeQuery"</h5>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => YouTubeResults = null">Close</button>
            </div>
            <div class="card-body">
                @if (YouTubeResults.Results?.Any() == true)
                {
                    <div class="list-group">
                        @foreach (var video in YouTubeResults.Results)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(video.ThumbnailUrl))
                                    {
                                        <img src="@video.ThumbnailUrl" alt="" 
                                             style="width: 120px; height: 90px; object-fit: cover;" 
                                             class="me-3 rounded" />
                                    }
                                    <div>
                                        <h6 class="mb-1">@video.Title</h6>
                                        <small class="text-muted">@video.Author • @video.Duration</small>
                                    </div>
                                </div>
                                <button class="btn btn-success btn-sm" @onclick="() => StartDownload(video)">
                                    ⬇️ Download
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted">No YouTube results found.</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string SearchQuery = "";
    private string SearchType = "artist";
    private bool IsSearching = false;
    private MusicBrainzSearchResultDto? SearchResults;
    private YouTubeSearchResult? YouTubeResults;
    private string YouTubeQuery = "";
    private string? Message;
    private string MessageClass = "alert-info";

    private bool HasResults => SearchResults?.Type switch
    {
        "artist" => SearchResults?.Artists?.Any() == true,
        "track" => SearchResults?.Tracks?.Any() == true,
        "release" => SearchResults?.Releases?.Any() == true,
        _ => false
    };

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            ShowError("Please enter a search query.");
            return;
        }

        IsSearching = true;
        YouTubeResults = null;

        try
        {
            SearchResults = SearchType switch
            {
                "artist" => await DownloadApi.SearchMusicBrainzArtistsAsync(SearchQuery),
                "track" => await DownloadApi.SearchMusicBrainzTracksAsync(SearchQuery),
                "album" => await DownloadApi.SearchMusicBrainzReleasesAsync(SearchQuery),
                _ => null
            };

            if (SearchResults == null)
            {
                ShowError("Failed to search MusicBrainz. Please try again.");
            }
            else if (!HasResults)
            {
                ShowInfo("No results found. Try a different search term.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching MusicBrainz");
            ShowError("An error occurred while searching.");
        }
        finally
        {
            IsSearching = false;
        }
    }

    private async Task SearchYouTube(string query, bool isArtist = false)
    {
        YouTubeQuery = query;
        try
        {
            YouTubeResults = await DownloadApi.SearchYouTubeAsync(query);
            if (YouTubeResults == null || !YouTubeResults.Results.Any())
            {
                ShowInfo($"No YouTube results found for '{query}'.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching YouTube");
            ShowError("Failed to search YouTube.");
        }
    }

    private async Task StartDownload(YouTubeVideo video)
    {
        try
        {
            var result = await DownloadApi.StartDownloadAsync(
                $"https://youtube.com/watch?v={video.VideoId}",
                video.Title,
                video.Author
            );

            if (result != null)
            {
                ShowSuccess($"Download started for: {video.Title}");
                // Navigate to home page to see download progress
                Navigation.NavigateTo("/");
            }
            else
            {
                ShowError("Failed to start download.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error starting download");
            ShowError("Failed to start download.");
        }
    }

    private void ClearSearch()
    {
        SearchQuery = "";
        SearchResults = null;
        YouTubeResults = null;
        Message = null;
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        MessageClass = "alert-success";
        StateHasChanged();
    }

    private void ShowError(string message)
    {
        Message = message;
        MessageClass = "alert-danger";
        StateHasChanged();
    }

    private void ShowInfo(string message)
    {
        Message = message;
        MessageClass = "alert-info";
        StateHasChanged();
    }
}

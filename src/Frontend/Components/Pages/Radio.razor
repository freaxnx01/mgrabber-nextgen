@page "/radio"
@using Frontend.Services
@inject DownloadApiService DownloadApi
@inject NavigationManager Navigation
@inject ILogger<Radio> Logger
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Radio - Music Grabber</PageTitle>

<div class="container">
    <h1>📻 Radio Now Playing</h1>
    <p class="text-muted">See what's playing on Swiss radio stations and extract audio instantly</p>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert @MessageClass" role="alert">
            @Message
        </div>
    }

    <!-- Station Selector -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Select Station</h5>
        </div>
        <div class="card-body">
            <div class="row">
                @if (Stations.Any())
                {
                    @foreach (var station in Stations)
                    {
                        <div class="col-md-4 mb-2">
                            <button class="btn @GetStationButtonClass(station.Id) w-100" 
                                    @onclick="() => SelectStationAsync(station.Id)">
                                @if (SelectedStation == station.Id)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                @station.Name
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <button class="btn btn-primary" @onclick="LoadStationsAsync">
                            Load Stations
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Now Playing -->
    @if (NowPlaying != null)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">🔴 Now Playing on @GetStationName(NowPlaying.Station)</h5>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h2 class="mb-2">@NowPlaying.Title</h2>
                        <h4 class="text-muted mb-3">@NowPlaying.Artist</h4>
                        <p class="mb-2">
                            <span class="badge bg-info">@NowPlaying.FormattedDuration</span>
                            <span class="badge bg-secondary ms-2">Started: @NowPlaying.PlayedAt.ToString("HH:mm")</span>
                        </p>
                        <div class="mt-3">
                            <button class="btn btn-success btn-lg me-2" @onclick="() => ExtractAudioAsync(NowPlaying)" disabled="@IsExtracting">
                                @if (IsExtracting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                ⬇️ Extract Audio
                            </button>
                            <button class="btn btn-outline-primary" @onclick="() => SearchYouTubeAsync(NowPlaying)">
                                🔍 Search YouTube
                            </button>
                        </div>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="p-4 bg-light rounded">
                            <span style="font-size: 6rem;">🎵</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Recent Playlist -->
    @if (Playlist?.Any() == true)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Recent Playlist</h5>
                <span class="badge bg-secondary">@Playlist.Count songs</span>
            </div>
            <div class="card-body">
                <div class="list-group">
                    @foreach (var song in Playlist.Skip(1)) // Skip now playing
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">@song.Title</h6>
                                <small class="text-muted">@song.Artist • @song.PlayedAt.ToString("HH:mm")</small>
                            </div>
                            <div class="btn-group">
                                <button class="btn btn-sm btn-success" @onclick="() => ExtractAudioAsync(song)" title="Extract Audio">
                                    ⬇️
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => SearchYouTubeAsync(song)" title="Search YouTube">
                                    🔍
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- YouTube Results Modal -->
    @if (ShowYouTubeResults && YouTubeResults?.Any() == true)
    {
        <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">YouTube Results for "@CurrentSong?.Title"</h5>
                        <button type="button" class="btn-close" @onclick="CloseYouTubeResults"></button>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">
                            @foreach (var video in YouTubeResults)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <img src="@video.ThumbnailUrl" alt="" style="width: 120px; height: 90px; object-fit: cover;" class="me-3 rounded" />
                                        <div>
                                            <h6 class="mb-1">@video.Title</h6>
                                            <small class="text-muted">@video.Author • @video.Duration</small>
                                        </div>
                                    </div>
                                    <button class="btn btn-success btn-sm" @onclick="() => DownloadVideoAsync(video)">
                                        ⬇️ Download
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseYouTubeResults">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<RadioStationDto> Stations = new();
    private List<RadioSongDto> Playlist = new();
    private RadioSongDto? NowPlaying;
    private string SelectedStation = "srf3";
    private bool IsLoading;
    private bool IsExtracting;
    private bool ShowYouTubeResults;
    private List<YouTubeVideoDto> YouTubeResults = new();
    private RadioSongDto? CurrentSong;
    private string? Message;
    private string MessageClass = "alert-info";
    private System.Threading.Timer? RefreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadStationsAsync();
        await SelectStationAsync(SelectedStation);
        
        // Auto-refresh every 30 seconds
        RefreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshPlaylistAsync();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    public void Dispose()
    {
        RefreshTimer?.Dispose();
    }

    private async Task LoadStationsAsync()
    {
        try
        {
            var result = await DownloadApi.GetRadioStationsAsync();
            if (result?.Any() == true)
            {
                Stations = result.ToList();
            }
            else
            {
                // Fallback stations
                Stations = new List<RadioStationDto>
                {
                    new() { Id = "srf1", Name = "Radio SRF 1" },
                    new() { Id = "srf3", Name = "Radio SRF 3" },
                    new() { Id = "srfvirus", Name = "Radio SRF Virus" }
                };
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load radio stations");
            ShowError("Failed to load radio stations.");
        }
    }

    private async Task SelectStationAsync(string stationId)
    {
        SelectedStation = stationId;
        IsLoading = true;

        try
        {
            await RefreshPlaylistAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load playlist for {Station}", stationId);
            ShowError("Failed to load playlist.");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RefreshPlaylistAsync()
    {
        try
        {
            var result = await DownloadApi.GetRadioPlaylistAsync(SelectedStation, 20);
            if (result != null)
            {
                Playlist = result.Songs?.ToList() ?? new List<RadioSongDto>();
                NowPlaying = result.NowPlaying ?? Playlist.FirstOrDefault();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to refresh playlist");
        }
    }

    private async Task ExtractAudioAsync(RadioSongDto song)
    {
        IsExtracting = true;
        CurrentSong = song;

        try
        {
            var result = await DownloadApi.DownloadRadioSongAsync(
                song.Station,
                "radio-user",
                "mp3",
                autoSelectBestMatch: true
            );

            if (result?.Success == true)
            {
                ShowSuccess($"Started downloading: {song.Artist} - {song.Title}");
                Navigation.NavigateTo("/");
            }
            else
            {
                // Show YouTube results for manual selection
                await SearchYouTubeAsync(song);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to extract audio");
            ShowError("Failed to start download.");
        }
        finally
        {
            IsExtracting = false;
        }
    }

    private async Task SearchYouTubeAsync(RadioSongDto song)
    {
        CurrentSong = song;
        
        try
        {
            var result = await DownloadApi.SearchYouTubeAsync($"{song.Artist} {song.Title}");
            if (result?.Results?.Any() == true)
            {
                YouTubeResults = result.Results.ToList();
                ShowYouTubeResults = true;
            }
            else
            {
                ShowError("No YouTube results found.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to search YouTube");
            ShowError("Failed to search YouTube.");
        }
    }

    private async Task DownloadVideoAsync(YouTubeVideoDto video)
    {
        try
        {
            var result = await DownloadApi.StartDownloadAsync(
                $"https://youtube.com/watch?v={video.VideoId}",
                video.Title,
                video.Author
            );

            if (result != null)
            {
                ShowSuccess($"Download started: {video.Title}");
                CloseYouTubeResults();
                Navigation.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download video");
            ShowError("Failed to start download.");
        }
    }

    private void CloseYouTubeResults()
    {
        ShowYouTubeResults = false;
        YouTubeResults.Clear();
    }

    private string GetStationButtonClass(string stationId)
    {
        return SelectedStation == stationId ? "btn-primary" : "btn-outline-primary";
    }

    private string GetStationName(string stationId)
    {
        return Stations.FirstOrDefault(s => s.Id == stationId)?.Name ?? stationId;
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        MessageClass = "alert-success";
        StateHasChanged();
    }

    private void ShowError(string message)
    {
        Message = message;
        MessageClass = "alert-danger";
        StateHasChanged();
    }

    // DTOs
    private class RadioStationDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
    }

    private class RadioSongDto
    {
        public string Artist { get; set; } = "";
        public string Title { get; set; } = "";
        public DateTime PlayedAt { get; set; }
        public string FormattedDuration { get; set; } = "";
        public bool IsPlayingNow { get; set; }
        public string Station { get; set; } = "";
    }

    private class RadioPlaylistResponseDto
    {
        public string Station { get; set; } = "";
        public RadioSongDto? NowPlaying { get; set; }
        public List<RadioSongDto> Songs { get; set; } = new();
    }

    private class YouTubeVideoDto
    {
        public string VideoId { get; set; } = "";
        public string Title { get; set; } = "";
        public string Author { get; set; } = "";
        public string Duration { get; set; } = "";
        public string ThumbnailUrl { get; set; } = "";
    }
}

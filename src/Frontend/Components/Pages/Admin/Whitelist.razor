@page "/admin/whitelist"
@using Frontend.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,SuperAdmin")]
@inject IDownloadApiService DownloadApi
@inject ILogger<Whitelist> Logger
@rendermode InteractiveServer

<PageTitle>Whitelist Management</PageTitle>

<div class="container">
    <h1>🛡️ Whitelist Management</h1>
    <p class="text-muted">Manage which users are allowed to access the application</p>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert @MessageClass" role="alert">
            @Message
        </div>
    }

    <!-- Search & Actions -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Search & Actions</span>
            <span class="text-muted">Total: @FilteredUsers.Count users</span>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">🔍</span>
                        <input type="text" class="form-control" @bind="SearchQuery" 
                               @bind:event="oninput" placeholder="Search users..." />
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <button class="btn btn-primary" @onclick="ShowAddDialog">
                        ➕ Add User
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card">
        <div class="card-header">
            <h5>Whitelisted Users</h5>
        </div>
        <div class="card-body">
            @if (IsLoading)
            {
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (FilteredUsers.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>User ID / Email</th>
                                <th>Added Date</th>
                                <th>Added By</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in FilteredUsers)
                            {
                                <tr>
                                    <td>@user.UserId</td>
                                    <td>@user.AddedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@user.AddedBy</td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">🟢 Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">🔴 Disabled</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" 
                                                    @onclick="() => ToggleStatus(user)"
                                                    title="@(user.IsActive ? "Disable" : "Enable")">
                                                ⚙️
                                            </button>
                                            <button class="btn btn-outline-danger" 
                                                    @onclick="() => ShowRemoveConfirm(user)"
                                                    title="Remove">
                                                🗑️
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <h3>🛡️</h3>
                    <p class="text-muted">No users whitelisted yet.</p>
                    <p class="text-muted">Add users to grant them access to the application.</p>
                    <button class="btn btn-primary" @onclick="ShowAddDialog">
                        ➕ Add First User
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add User Dialog -->
@if (ShowAddDialogVisible)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">➕ Add User to Whitelist</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddDialog"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="userEmail" class="form-label">Email or User ID</label>
                        <input type="email" class="form-control" id="userEmail" 
                               @bind="NewUserEmail" placeholder="user@example.com" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="sendEmail" 
                               @bind="SendWelcomeEmail" />
                        <label class="form-check-label" for="sendEmail">
                            Send welcome email
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddDialog">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="AddUserAsync" 
                            disabled="@IsAdding">
                        @if (IsAdding)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Add to List
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Remove Confirm Dialog -->
@if (ShowRemoveDialogVisible)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">⚠️ Remove User?</h5>
                    <button type="button" class="btn-close" @onclick="CloseRemoveDialog"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to remove <strong>@SelectedUser?.UserId</strong> from the whitelist?</p>
                    <p class="text-muted">This will prevent them from accessing the application.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseRemoveDialog">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="RemoveUserAsync"
                            disabled="@IsRemoving">
                        @if (IsRemoving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Remove
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<WhitelistEntryDto> Users = new();
    private List<WhitelistEntryDto> FilteredUsers => 
        string.IsNullOrWhiteSpace(SearchQuery) 
            ? Users 
            : Users.Where(u => u.UserId.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)).ToList();
    
    private string SearchQuery = string.Empty;
    private bool IsLoading = true;
    private string? Message;
    private string MessageClass = "alert-info";

    // Add Dialog
    private bool ShowAddDialogVisible = false;
    private string NewUserEmail = string.Empty;
    private bool SendWelcomeEmail = true;
    private bool IsAdding = false;

    // Remove Dialog
    private bool ShowRemoveDialogVisible = false;
    private WhitelistEntryDto? SelectedUser;
    private bool IsRemoving = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        IsLoading = true;
        try
        {
            var result = await DownloadApi.GetWhitelistAsync();
            Users = result ?? new List<WhitelistEntryDto>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load whitelist");
            ShowError("Failed to load whitelist. Please try again.");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ShowAddDialog()
    {
        NewUserEmail = string.Empty;
        SendWelcomeEmail = true;
        ShowAddDialogVisible = true;
    }

    private void CloseAddDialog()
    {
        ShowAddDialogVisible = false;
    }

    private async Task AddUserAsync()
    {
        if (string.IsNullOrWhiteSpace(NewUserEmail))
        {
            ShowError("Please enter a valid email or user ID.");
            return;
        }

        IsAdding = true;
        try
        {
            await DownloadApi.AddToWhitelistAsync(new AddToWhitelistRequestDto(
                NewUserEmail, 
                SendWelcomeEmail));
            
            ShowAddDialogVisible = false;
            ShowSuccess($"Added {NewUserEmail} to whitelist successfully.");
            await LoadUsersAsync();
        }
        catch (InvalidOperationException)
        {
            ShowError($"{NewUserEmail} is already whitelisted.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to add user to whitelist");
            ShowError("Failed to add user. Please try again.");
        }
        finally
        {
            IsAdding = false;
        }
    }

    private async Task ToggleStatus(WhitelistEntryDto user)
    {
        try
        {
            await DownloadApi.UpdateWhitelistStatusAsync(user.Id, !user.IsActive);
            ShowSuccess($"{user.UserId} is now {(!user.IsActive ? "active" : "disabled")}.");
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update whitelist status");
            ShowError("Failed to update status. Please try again.");
        }
    }

    private void ShowRemoveConfirm(WhitelistEntryDto user)
    {
        SelectedUser = user;
        ShowRemoveDialogVisible = true;
    }

    private void CloseRemoveDialog()
    {
        ShowRemoveDialogVisible = false;
        SelectedUser = null;
    }

    private async Task RemoveUserAsync()
    {
        if (SelectedUser == null) return;

        IsRemoving = true;
        try
        {
            await DownloadApi.RemoveFromWhitelistAsync(SelectedUser.Id);
            ShowRemoveDialogVisible = false;
            ShowSuccess($"Removed {SelectedUser.UserId} from whitelist.");
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to remove user from whitelist");
            ShowError("Failed to remove user. Please try again.");
        }
        finally
        {
            IsRemoving = false;
            SelectedUser = null;
        }
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        MessageClass = "alert-success";
        StateHasChanged();
    }

    private void ShowError(string message)
    {
        Message = message;
        MessageClass = "alert-danger";
        StateHasChanged();
    }
}

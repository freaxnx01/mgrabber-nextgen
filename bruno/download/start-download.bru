meta {
  name: Start Download
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/downloads
  body: json
  auth: none
}

body:json {
  {
    "userId": "{{userId}}",
    "videoId": "5NV6Rdv1h3Q",
    "title": "Daft Punk - Get Lucky",
    "artist": "Daft Punk",
    "format": "mp3",
    "qualityKbps": 320
  }
}

assert {
  res.status: eq 202
  res.body.jobId: isDefined
}
